{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Song",
  "description": "Schema for a single song object returned by the GraphQL songs query",
  "type": "object",
  "required": ["id", "title", "album", "author"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "integer",
      "description": "Unique song identifier"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "album": {
      "type": "string"
    },
    "author": {
      "type": "object",
      "required": ["name", "homeTown"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "homeTown": {
          "type": ["string", "null"]
        }
      }
    }
  }
}


