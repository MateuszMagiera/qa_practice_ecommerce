{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Employee",
  "description": "Schema for a single employee object returned by GET /api/v1/employees",
  "type": "object",
  "required": ["id", "firstName", "lastName", "email", "dob"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "integer",
      "description": "Unique employee identifier"
    },
    "firstName": {
      "type": "string",
      "minLength": 1
    },
    "lastName": {
      "type": "string",
      "minLength": 1
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "dob": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Date of birth in YYYY-MM-DD format"
    }
  }
}

