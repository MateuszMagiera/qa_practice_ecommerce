{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GraphQL Songs Response",
  "description": "Schema for the full GraphQL response of the GetAllSongs query",
  "type": "object",
  "required": [
    "data"
  ],
  "properties": {
    "data": {
      "type": "object",
      "required": [
        "songs"
      ],
      "properties": {
        "songs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "song.json"
          }
        }
      }
    }
  }
}